# Site (used for sitemap.xml, robots.txt, metadataBase)
# In production, set to https://your-domain.tld (no trailing slash).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Anthropic
ANTHROPIC_API_KEY=

# Supabase Postgres (server-only — never NEXT_PUBLIC_)
# Project Settings → Database → Connection pooling → Transaction (port 6543).
# Format:
#   postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Upstash Redis (rate limiting + reaction dedupe — server-only)
# Console → your DB → "REST API" panel. Required in production; if unset
# the app falls back to in-memory counters which don't survive serverless
# cold starts (i.e. rate limiting is effectively off).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Per-deploy salt for hashing client IPs before they're used as rate-limit
# keys. Any random string (e.g. `openssl rand -hex 32`). Rotate to invalidate
# all existing rate-limit / dedupe entries.
IP_HASH_SALT=

# Monetization
NEXT_PUBLIC_MONETAG_ZONE_ID=
LEMON_PREMIUM_URL=
LEMON_WEBHOOK_SECRET=
NEXT_PUBLIC_BMC_USERNAME=

# Private Korean preview (/glorious) — set to any string. Empty = page open.
GLORIOUS_PASSWORD=
